# 复制此文件为 .env，填入真实值后不要提交到 Git
# cp .env.example .env

# Telegram Bot Token（从 @BotFather 获取）
TG_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram 推送频道（如 @dmvpsjk）
TG_CHANNEL_ID=@your_channel_here

# Telegram 管理员数字 ID（从 @userinfobot 获取）
TG_ADMIN_ID=YOUR_ADMIN_ID_HERE

# 后台管理密码（自定义，建议改掉默认值）
ADMIN_TOKEN=change_this_password
